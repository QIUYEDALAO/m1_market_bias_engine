{
  "name": "m1_five_dimension_hybrid_decision_policy",
  "mode": "research_only_lite_risk_filter",
  "version": 2,
  "inputs": {
    "round1_freeze_report": "reports/backtest/M1_MARKET_BIAS_ROUND1_FREEZE_REPORT.json",
    "round1_conclusion": "NO_STABLE_EDGE_FOUND",
    "round2_bucket_report": "reports/backtest/m1_round2_bucket_backtest_report.json",
    "five_dimension_reference": "五维赛事评估系统-完整版.md"
  },
  "roles": {
    "M1_Market_Bias": {
      "role": "primary_market_edge_screening",
      "can_create_candidate": true,
      "candidate_type": "research_candidate_only",
      "requires_stable_market_edge": true
    },
    "Five_Dimension_Lite_Risk_Filter": {
      "role": "lite_risk_filter_explanation_and_downgrade",
      "can_create_candidate": false,
      "can_upgrade_without_m1_market_edge": false,
      "can_downgrade_m1_candidate": true,
      "full_scoring_status": "PAUSED",
      "allowed_fields": [
        "lineup_status",
        "major_absence",
        "rotation_risk",
        "match_type",
        "market_conflict",
        "weather_extreme",
        "motivation_unclear"
      ]
    }
  },
  "decision_order": [
    "validate_data_contract",
    "require_m1_market_edge",
    "block_when_no_market_edge",
    "apply_lite_risk_filter",
    "downgrade_high_risk_items",
    "emit_research_only_label"
  ],
  "hard_rules": {
    "FiveDimension_can_create_candidate": false,
    "M1_can_create_candidate": true,
    "No_market_edge_no_candidate": true,
    "FiveDimension_support_without_M1_edge": "PASS",
    "M1_support_with_FiveDimension_high_risk": "WATCH_OR_PASS",
    "full_five_dimension_scoring": "PAUSED",
    "lite_risk_filter_enabled": true,
    "lite_allowed_fields": [
      "lineup_status",
      "major_absence",
      "rotation_risk",
      "match_type",
      "market_conflict",
      "weather_extreme",
      "motivation_unclear"
    ],
    "deny_non_lite_five_dimension_fields": true,
    "round2_bucket_backtest_is_not_stability_filter": true,
    "current_match_matching_allowed": false,
    "paper_play_allowed": false,
    "recommendations_generated": false,
    "official_written": false,
    "pending_written": false,
    "qq_written": false,
    "old_system_touched": "NO"
  },
  "allowed_output_labels": [
    "PASS",
    "WATCH_RESEARCH_ONLY",
    "M1_RESEARCH_CANDIDATE",
    "DOWNGRADED_BY_FIVE_DIMENSION_RISK",
    "BLOCKED_NO_MARKET_EDGE",
    "BLOCKED_CURRENT_MATCH_MATCHING_DISABLED",
    "BLOCKED_PAPER_PLAY_DISABLED"
  ],
  "forbidden_outputs": [
    "betting_recommendation",
    "official_record",
    "pending_record",
    "qq_message",
    "live_bet_instruction",
    "v3_v4_mutation"
  ],
  "downgrade_matrix": [
    {
      "m1_market_edge": false,
      "five_dimension_signal": "any",
      "output_label": "PASS",
      "reason": "No M1 market edge means no candidate."
    },
    {
      "m1_market_edge": true,
      "five_dimension_risk": "LOW",
      "output_label": "M1_RESEARCH_CANDIDATE",
      "reason": "M1 supports research candidate and Lite risk is low."
    },
    {
      "m1_market_edge": true,
      "five_dimension_risk": "MEDIUM",
      "output_label": "WATCH_RESEARCH_ONLY",
      "reason": "M1 support remains research-only, with risk downgrade."
    },
    {
      "m1_market_edge": true,
      "five_dimension_risk": "HIGH",
      "output_label": "DOWNGRADED_BY_FIVE_DIMENSION_RISK",
      "reason": "Lite high risk can downgrade or block M1-supported research."
    },
    {
      "m1_market_edge": true,
      "five_dimension_risk": "MISSING_REQUIRED_EVIDENCE",
      "output_label": "WATCH_RESEARCH_ONLY",
      "reason": "Missing risk evidence cannot promote a candidate."
    }
  ],
  "next_phase_route": [
    "round2_stability_filter",
    "round2_candidate_audit_if_any",
    "round2_candidate_stress_test_if_any",
    "lite_risk_filter_schema_audit",
    "hybrid_offline_simulation",
    "hybrid_freeze_report",
    "separate_approval_before_current_matching_or_paper_play"
  ]
}
